<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPlayerBackground"
    android:orientation="vertical">

    <!-- 顶部分隔线 -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorPlayerShadow" />

    <!-- 可滚动内容区域 -->
    <ScrollView
        android:id="@+id/scrollViewContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- 歌曲/当前信息 - 自动调整大小 -->
            <TextView
                android:id="@+id/textViewGeneralInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textAlignment="center"
                android:autoSizeMaxTextSize="28sp"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeTextType="uniform"
                android:maxHeight="72sp"
                android:minHeight="36sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="歌曲名称 - 艺术家" />

            <!-- 电台名称 -->
            <TextView
                android:id="@+id/textViewStationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                tools:text="电台名称" />

            <!-- ViewPager 封面和播放信息 -->
            <androidx.viewpager.widget.ViewPager
                android:id="@+id/pagerArtAndInfo"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="24dp">

                <androidx.viewpager.widget.PagerTabStrip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:textColor="@color/colorPrimary" />

            </androidx.viewpager.widget.ViewPager>

            <!-- 时间和网络使用信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/textViewTimePlayed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    tools:text="3:44" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | "
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/textViewTimeCached"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    tools:text="缓冲: -10s" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | "
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/textViewNetworkUsageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    tools:text="1.5 MB" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="@color/colorPlayerShadow" />

            <!-- 无电台提示 -->
            <TextView
                android:id="@+id/textViewNoStation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/select_station_hint"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:padding="32dp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <!-- 底部分隔线 -->
    <View
        android:id="@+id/dividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorPlayerShadow" />

    <!-- 播放控制区 -->
    <LinearLayout
        android:id="@+id/layoutPlaybackControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <!-- 上一曲 -->
        <ImageButton
            android:id="@+id/buttonPrev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/previous_station"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_skip_previous_circle"
            app:tint="@color/colorPrimary" />

        <!-- 播放/暂停按钮 - 大圆圈 -->
        <ImageButton
            android:id="@+id/buttonPlay"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/play_pause"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play_circle"
            app:tint="@color/colorPrimary" />

        <!-- 下一曲 -->
        <ImageButton
            android:id="@+id/buttonNext"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/next_station"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_skip_next_circle"
            app:tint="@color/colorPrimary" />

        <!-- 退出全屏按钮 -->
        <ImageButton
            android:id="@+id/buttonFullscreenExit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/exit_fullscreen"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_fullscreen_exit"
            android:visibility="gone"
            app:tint="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>