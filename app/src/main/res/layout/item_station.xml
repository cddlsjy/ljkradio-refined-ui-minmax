<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 播放指示器 - 左侧竖条 -->
        <View
            android:id="@+id/playing_indicator"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@color/playingIndicator"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- 电台图标容器 -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp">

            <!-- 默认电台图标背景 -->
            <ImageView
                android:id="@+id/station_icon_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_station_icon"
                android:padding="8dp"
                android:src="@drawable/ic_radio"
                app:tint="@color/colorPrimary"
                tools:ignore="ContentDescription" />

            <!-- 透明圆形遮罩 -->
            <ImageView
                android:id="@+id/transparent_circle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_transparent_circle"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <!-- 电台信息区域 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 电台名称 -->
            <TextView
                android:id="@+id/station_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="BBC World Service" />

            <!-- 电台描述 -->
            <TextView
                android:id="@+id/station_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="BBC 国际广播服务"
                tools:visibility="visible" />

            <!-- 播放状态指示 -->
            <TextView
                android:id="@+id/playback_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="正在播放"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- 删除按钮 (可选) -->
        <ImageButton
            android:id="@+id/delete_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_station"
            android:src="@drawable/ic_delete"
            android:visibility="gone"
            app:tint="@color/text_secondary"
            tools:visibility="visible" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>