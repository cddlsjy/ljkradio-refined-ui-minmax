<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:background="@drawable/dialog_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/volume_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="音量图标"
                android:src="@drawable/ic_volume_up"
                app:tint="@color/colorPrimary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/volume_slider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:value="1.0"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:labelBehavior="gone"
                app:thumbColor="@color/colorPrimary"
                app:trackColorActive="@color/colorPrimary"
                app:trackColorInactive="@color/divider" />

        </LinearLayout>

        <RadioGroup
            android:id="@+id/decode_mode_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/radio_hardware"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="硬解码"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radio_software"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="软解码" />

        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自动播放"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/auto_play_last_station_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/colorPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自动全屏"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/auto_fullscreen_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                app:thumbTint="@color/colorPrimary" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="全屏设置"
            android:textSize="16sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="显示方案"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <Spinner
                android:id="@+id/fullscreen_display_mode_spinner"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/colorPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Logo形状"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <Spinner
                android:id="@+id/fullscreen_logo_shape_spinner"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/colorPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="背景颜色"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <Spinner
                android:id="@+id/fullscreen_background_color_spinner"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/colorPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/button_import_m3u"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/import_m3u_select_file"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/colorPrimary" />

            <Button
                android:id="@+id/button_clear_stations"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="清除电台"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#E53935" />

            <Button
                android:id="@+id/button_export_m3u"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/export_m3u_title"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/colorPrimary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
