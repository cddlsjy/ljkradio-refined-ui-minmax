<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- 上方播放控制区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPlayerBackground"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 电台信息行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 电台图标 -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/stationIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="@string/select_station_hint"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/Circle"
                app:srcCompat="@drawable/ic_default_station_image_180dp" />

            <!-- 文本信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewStationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    tools:text="AsiaFM亚洲音乐台" />

                <TextView
                    android:id="@+id/textViewGeneralInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    tools:text="汪峰 - 生来彷徨" />

            </LinearLayout>

            <!-- 退出按钮 -->
            <ImageButton
                android:id="@+id/buttonFullscreenExit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/exit_fullscreen"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_expand_more"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- 播放控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <ImageButton
                android:id="@+id/buttonPrev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous_station"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/buttonPlay"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/shape_player_button_black"
                android:contentDescription="@string/play_pause"
                android:scaleType="centerInside"
                android:src="@drawable/ic_play_white" />

            <ImageButton
                android:id="@+id/buttonNext"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next_station"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 电台列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/stationsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"
        android:scrollbars="vertical"
        tools:listitem="@layout/item_station" />

</LinearLayout>
